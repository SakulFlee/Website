---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import { Icon } from 'astro-icon/components';
---

<header>
	<nav class="navbar" role="navigation" aria-label="main navigation">
	  <div class="navbar-brand">
	  	<a class="navbar-item" href="/">
				<h2 class="navbar-item is-size-5 has-text-weight-bold has-text-white">{SITE_TITLE}</h2>
			</a>
	  </div>
	
	  <div class="navbar-menu">
	    <div class="navbar-start">
				<HeaderLink href="/"><Icon name="famicons:home" />Home</HeaderLink>
				<HeaderLink href="/projects"><Icon name="famicons:git-branch" />Projects</HeaderLink>
				<HeaderLink href="/blog"><Icon name="famicons:library" />Blog</HeaderLink>
	    </div>
	  </div>
	</nav>
</header>

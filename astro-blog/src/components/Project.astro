---
import type { HTMLAttributes } from "astro/types";

interface ProjectData {
  title: string;
  subtitle: string;
  image?: string;
  link?: string;
}

type Props = ProjectData & HTMLAttributes<"div">;

const { title, subtitle, link, image, ...props } = Astro.props;
---

<div class="column" {...props}>
  <h2 class="title">{title}</h2>
  <h3 class="subtitle">{subtitle}</h3>

  <slot />

  {
    image && (
      <>
        <br />
        <img src={image} />
      </>
    )
  }

  {
    link && (
      <>
        <br />
        <b>LINK HERE</b>
      </>
    )
  }
</div>

    <left class="column">
      <Orbital />
      <HomeLab />
      <Tickify />
      <FluidTransport />
    </left>
    <right class="column">
      <VodafoneQualitics />
      <PigVocalizations />
      <TrafficLights />
      <GeoLocation />
    </right>
  </div>
</section>
